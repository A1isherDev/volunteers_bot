BOT_TOKEN=123456:ABC-DEF...
# Comma-separated Telegram user IDs (volunteer admins). These users get an automatic DB stub
# (no full registration), can always use /admin, /add_region, and are never blocked by empty regions.
ADMIN_IDS=111111111,222222222
# Optional: explicit super-admins; if empty, ADMIN_IDS are treated as super-admins for the panel
SUPER_ADMIN_IDS=
# Admin group chat id (negative for supergroups, e.g. -1001234567890)
ADMIN_GROUP_ID=-1001234567890
# Optional: forum topic id for support tickets (same supergroup)
# ADMIN_TICKET_TOPIC_ID=12345

# Redis — required (FSM, rate limits, metrics, news queue; multi-worker safe)
REDIS_URL=redis://localhost:6379/0
# NEWS_QUEUE_KEY=volunteers_bot:news_queue

# sqlite (default) or PostgreSQL:
# DATABASE_URL=sqlite+aiosqlite:///./volunteers_bot.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/volunteers
# Apply schema: alembic upgrade head (tables are not created at startup)

# Observability
# JSON_LOGS=1
# LOG_LEVEL=INFO
# SENTRY_DSN=

# News worker tuning (~25 msg/sec default)
# NEWS_MESSAGES_PER_SEC=25
# NEWS_MAX_RETRIES=3
# NEWS_RETRY_BASE_DELAY_SEC=0.5
# NEWS_DLQ_KEY=volunteers_bot:news_dlq
# FSM_REDIS_KEY_PREFIX=fsm

# Rate limit: Redis sliding window when REDIS_URL set (multi-worker)
# RATE_LIMIT_USE_REDIS=1

# Google Sheets (optional reporting)
# GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json
# GOOGLE_SHEET_ID=spreadsheet_id_from_url

# Optional REST API (run: uvicorn app.api.main:app --host 127.0.0.1 --port 8080)
# API_ENABLE=0
# API_HOST=127.0.0.1
# API_PORT=8080

BROADCAST_BATCH_SIZE=25
BROADCAST_DELAY_SEC=0.05

RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW_SEC=60
# Seconds between new support tickets or suggestions per user (0 disables)
CREATION_COOLDOWN_SEC=45
