BOT_TOKEN=123456:ABC-DEF...
# Comma-separated Telegram user IDs (volunteer admins). These users get an automatic DB stub
# (no full registration), can always use /admin, /add_region, and are never blocked by empty regions.
ADMIN_IDS=111111111,222222222
# Optional: explicit super-admins; if empty, ADMIN_IDS are treated as super-admins for the panel
SUPER_ADMIN_IDS=
# Admin group chat id (negative for supergroups, e.g. -1001234567890)
ADMIN_GROUP_ID=-1001234567890

# sqlite (default) or PostgreSQL:
# DATABASE_URL=sqlite+aiosqlite:///./volunteers_bot.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/volunteers

BROADCAST_BATCH_SIZE=25
BROADCAST_DELAY_SEC=0.05

RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW_SEC=60
# Seconds between new support tickets or suggestions per user (0 disables)
CREATION_COOLDOWN_SEC=45
